# ============================================================
# Compa — Variables de entorno (Desarrollo Local)
# Copiar a .env y completar los valores reales
# ============================================================

# Base de datos PostgreSQL+PostGIS
DATABASE_URL=postgresql+asyncpg://compa_user:compa_pass@compa-db:5432/compa_dev

# Redis (broker Celery + sesiones conversacionales)
REDIS_URL=redis://compa-redis:6379

# Seguridad JWT
SECRET_KEY=cambia-esto-por-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-...

# Anthropic (Claude Sonnet — configurable)
ANTHROPIC_API_KEY=sk-ant-...

# Meta / WhatsApp Business API
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=

# Stripe (pagos)
STRIPE_SECRET_KEY=

# Ambiente
ENV=development
LOG_LEVEL=INFO
