# ============================================================
# Compa — Variables de entorno (PRODUCCIÓN)
# ============================================================
# Copia este archivo a .env en el VPS y rellena los valores reales.
# NUNCA commitear el .env real al repositorio.
# ============================================================

# ── Base de datos PostgreSQL ────────────────────────────────
# ⚠️  CAMBIAR compa_pass por contraseña fuerte (openssl rand -base64 32)
POSTGRES_DB=compa_prod
POSTGRES_USER=compa_user
POSTGRES_PASSWORD=<CAMBIAR_POR_CLAVE_FUERTE>
DATABASE_URL=postgresql+asyncpg://compa_user:<CAMBIAR_POR_CLAVE_FUERTE>@compa-db:5432/compa_prod

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://compa-redis:6379

# ── Seguridad JWT ───────────────────────────────────────────
# ⚠️  Generar con: openssl rand -hex 32
SECRET_KEY=<GENERAR_CON_openssl_rand_hex_32>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI (opcional — solo si usan GPT en algún flujo) ────
OPENAI_API_KEY=

# ── Anthropic Claude ────────────────────────────────────────
# Usado por el normalizador IA y el agente de WhatsApp
ANTHROPIC_API_KEY=<PONER_API_KEY_REAL>

# ── Meta / WhatsApp Business API ───────────────────────────
META_WHATSAPP_TOKEN=<PONER_TOKEN_PRODUCCION>
META_PHONE_NUMBER_ID=955442064328554
META_VERIFY_TOKEN=<CAMBIAR_POR_NUEVO_TOKEN_SEGURO>
META_WABA_ID=1601523541121705

# ── Stripe (pagos) ──────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── CORS — orígenes permitidos ──────────────────────────────
# Separados por coma. Incluir dominio del frontend en Vercel
ALLOWED_ORIGINS=https://app.compa.ve,https://www.compa.ve

# ── Ambiente ────────────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO
